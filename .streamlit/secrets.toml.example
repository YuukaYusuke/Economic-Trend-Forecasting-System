# Salin isi ke Streamlit Cloud → App settings → Secrets
# (JANGAN commit file secrets.toml ke Git)

# API Alpha Vantage (opsional — Frankfurter tetap dipakai untuk bulk/realtime)
ALPHAVANTAGE_API_KEY = "isi_api_key_anda"

# Atau format nested:
# [alphavantage]
# api_key = "isi_api_key_anda"

[app]
# Di Cloud: false agar tidak melatih model di server (lambat & boros memori)
allow_runtime_training = false
